{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ASTRA Launcher",
  "version": "1.3.0",
  "identifier": "com.astra.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "splash",
        "title": "ASTRA — Загрузка",
        "url": "/splash.html",
        "width": 300,
        "height": 358,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "alwaysOnTop": false
      },
      {
        "label": "main",
        "title": "ASTRA Launcher",
        "url": "/index.html",
        "width": 960,
        "height": 600,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "visible": false,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
