{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ASTRA Launcher",
  "version": "1.9.8",
  "identifier": "com.astra.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' asset: https://asset.localhost data: https://forum.astra-rp.fun; connect-src 'self' https://github.com https://api.github.com https://runtime.fivem.net http://185.176.94.21 https://catbox.moe https://streams.fluxfm.de https://forum.astra-rp.fun ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "label": "splash",
        "title": "ASTRA — Загрузка",
        "url": "/splash.html",
        "width": 300,
        "height": 358,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "alwaysOnTop": false
      },
      {
        "label": "main",
        "title": "ASTRA Launcher",
        "url": "/index.html",
        "width": 960,
        "height": 600,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "visible": false,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/banner.bmp",
        "sidebarImage": "icons/sidebar.bmp"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZGRDA5QkY5NTNCMjEwQkQKUldTOUVMSlQrWnZRYjIyd1prWGpxcEhydU0vbk9yTk9QY1VJQlFIcldFY2E2YnhaekdWWURITUwK",
      "endpoints": [
        "https://github.com/Districkov/Astra_launcher/releases/latest/download/latest.json"
      ]
    }
  }
}
